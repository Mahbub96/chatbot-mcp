# Copy to `.env` and fill values.

# =========================
# NVIDIA NIM (hosted) upstream
# =========================
# Required for hosted NIM access.
NVIDIA_API_KEY=your_nvidia_api_key_here

# OpenAI-compatible chat/completions endpoint for NVIDIA integrate API.
# (You generally do not need to change this.)
BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
# Seconds between SSE chunks when streaming chat (slow TTFT / queueing); avoids ReadTimeout at 60s default.
STREAM_CHAT_READ_TIMEOUT_SECONDS=300
# OpenAI-compatible embeddings endpoint (real vector embeddings)
EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1/embeddings
# Embedding model id (must be available in your NVIDIA account)
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
# Embedding dimension expected by local vector index
EMBEDDING_DIM=1024
# HTTP timeout for embedding calls
EMBEDDING_TIMEOUT_SECONDS=20
# Cooldown after embedding endpoint failure (seconds)
EMBEDDING_FAILURE_COOLDOWN_SECONDS=300

# Local gateway URL used by Cursor MCP bridge server.
GATEWAY_URL=http://127.0.0.1:8000

# Gateway per-IP rate limit (chat + images). Set true for solo/local use — disables local 429 throttling only.
# NVIDIA still enforces its own quotas (e.g. ~40 requests/minute depending on plan).
RATE_LIMIT_DISABLED=true
# When RATE_LIMIT_DISABLED=false: max requests per client IP within the window.
# RATE_LIMIT_WINDOW_SECONDS=100
# RATE_LIMIT_MAX_REQUESTS=100

# =========================
# Model routing
# =========================
# Default upstream model id (used for non-Bangla messages)
DEFAULT_MODEL=meta/llama-3.1-70b-instruct

# Optional: if set, Bangla text routes to this model id.
# Example (choose one available in your NIM account):
# BANGLA_MODEL=qwen3-30b-a3b-instruct-2507
BANGLA_MODEL=

# Optional: if set, code-heavy prompts route to this model id.
# Suggested coding model:
CODE_MODEL=qwen/qwen3-coder-480b-a35b-instruct

# =========================
# Vision routing (images)
# =========================
# NOTE: Free hosted VLM endpoints may change over time.
# Set this to a vision-capable model id available in your NIM account.
# Example ids from NVIDIA catalog (availability depends on your endpoint):
# - meta/llama-3.2-11b-vision-instruct
# - nvidia/llama-3.1-nemotron-nano-vl-8b-v1
VISION_MODEL=meta/llama-3.2-90b-vision-instruct
# Optional comma-separated fallback models for image understanding.
VISION_FALLBACK_MODELS=meta/llama-3.2-11b-vision-instruct,nvidia/llama-3.1-nemotron-nano-vl-8b-v1
# When true, try fallback list first (latency-first), then VISION_MODEL.
VISION_SPEED_FIRST=false
# Max wait time for image analysis in streamed chat responses.
VISION_STREAM_TIMEOUT_SECONDS=90
# Max wait per individual vision model attempt before trying fallback.
VISION_PER_MODEL_TIMEOUT_SECONDS=30

# Dedicated text-to-image model id (OpenAI images endpoint style)
IMAGE_GEN_MODEL=qwen/qwen-image
# Optional override for image generation endpoint:
# IMAGE_BASE_URL=https://integrate.api.nvidia.com/v1/images/generations

# Dedicated image-edit model id
IMAGE_EDIT_MODEL=qwen/qwen-image-edit
# Optional override for image edit endpoint:
# IMAGE_EDIT_BASE_URL=https://integrate.api.nvidia.com/v1/images/edits

# =========================
# Persistent memory (RAG-style MVP)
# =========================
# Enable/disable memory retrieval + storage in chat pipeline
MEMORY_ENABLED=true
# SQLAlchemy DB URL (SQLite by default; swappable to Postgres/MySQL later)
MEMORY_SQLITE_URL=sqlite:///./files/memory.db
# FAISS persistent directory path
MEMORY_VECTOR_PATH=./files/faiss_store
# Vector backend: faiss | pgvector
MEMORY_VECTOR_BACKEND=faiss
# Persist FAISS index/metadata every N new vectors (higher = faster writes, slightly less crash-safe)
MEMORY_VECTOR_PERSIST_EVERY=50
# Vector index backend: hnsw (fast ANN) or flat (exact linear)
MEMORY_VECTOR_INDEX_TYPE=hnsw
# HNSW tuning (higher search = better recall, slower query)
MEMORY_VECTOR_HNSW_M=32
MEMORY_VECTOR_HNSW_EF_SEARCH=128
# pgvector HNSW tuning (used when MEMORY_VECTOR_BACKEND=pgvector)
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64
# Number of memory items to inject per request
MEMORY_TOP_K=5
# Minimum vector score threshold for retrieval
MEMORY_MIN_SCORE=0.20
# When strict query/slot matching finds nothing, inject retrieval hits for non-personal prompts (score / overlap gated).
MEMORY_SEMANTIC_CONTEXT_FALLBACK_ENABLED=true
MEMORY_SEMANTIC_CONTEXT_FALLBACK_MIN_SCORE=0.20
MEMORY_SEMANTIC_CONTEXT_FALLBACK_MIN_TOKEN_OVERLAP=0.12
MEMORY_SEMANTIC_CONTEXT_FALLBACK_MAX_CHARS=520
# Auto store user facts from chat turns
MEMORY_AUTO_STORE=true
# Store assistant replies as memory candidates (off by default for lower pollution risk)
MEMORY_STORE_ASSISTANT_TURNS=false
# Enable expensive cross-scope lexical fallback only when needed
MEMORY_ANY_SCOPE_FALLBACK_ENABLED=false
# Minimum chars required before failure-path memory write attempt
MEMORY_FAILURE_STORE_MIN_CHARS=20
# Minimum importance score (0–1) to upsert long_term normalized entities from extracted facts.
LONG_TERM_PROMOTE_MIN_SCORE=0.6
# Max records per memory scope before pruning oldest items
MEMORY_MAX_ITEMS=5000
# Max short-term trace rows per memory scope (question/response audit trail)
SHORT_TERM_TRACE_MAX_ITEMS=20000
# Max age (hours) for short-term memory rows before TTL cleanup
SHORT_TERM_RETENTION_HOURS=24
# Max short-term queue rows per scope before overflow pruning
SHORT_TERM_MAX_QUEUE_ITEMS=25000
# Max short-term retrieval log rows per scope before overflow pruning
SHORT_TERM_MAX_RETRIEVAL_LOG_ITEMS=25000
# Clear all short-term memory on service restart
SHORT_TERM_CLEAR_ON_RESTART=true
# Async memory queue backend: inprocess | rq
MEMORY_QUEUE_BACKEND=inprocess
# Redis URL for RQ backend
MEMORY_REDIS_URL=redis://127.0.0.1:6379/0
# RQ queue name for memory jobs
MEMORY_RQ_QUEUE=memory

# =========================
# Production runtime
# =========================
# Global request rate-limit window (seconds)
RATE_LIMIT_WINDOW_SECONDS=100
# Max requests allowed within window per client IP
RATE_LIMIT_MAX_REQUESTS=100
# Enable structured JSON request logs from middleware
LOG_JSON=true
# Run shadow retrieval comparison on a sampled subset of requests (0.0-1.0)
SHADOW_MONITOR_SAMPLE_RATE=0.25
# Skip shadow compare on slower retrieval paths to protect p95 latency.
SHADOW_MONITOR_MAX_RETRIEVAL_MS=120
# When true, DEBUG_MODE attaches verbose root/debug file logging (see DEBUG_LOG_* below).
DEBUG_LOG_TO_FILE=true
# Default local debug file path used when DEBUG_MODE enables debug log-to-file.
DEBUG_LOG_FILE=./mcp.log
# Per-request step traces (handle_chat_completions step N ...). When STEP_LOG_ENABLED=true,
# these go to STEP_LOG_FILE regardless of DEBUG_MODE.
STEP_LOG_ENABLED=false
STEP_LOG_FILE=./step.log
# Max wait time for image analysis in streamed chat responses.
VISION_STREAM_TIMEOUT_SECONDS=90
# Status update cadence while waiting for first text token in streamed chat.
TEXT_STREAM_STATUS_INTERVAL_SECONDS=3
# Maximum idle timeout windows allowed after first streamed token.
MAX_STREAM_IDLE_TIMEOUTS=3
# Hard cap on streaming time after first token to control tail latency.
MAX_STREAM_POST_FIRST_TOKEN_SECONDS=25
# Max wait for first streamed text token before timeout fallback.
TEXT_STREAM_FIRST_TOKEN_TIMEOUT_SECONDS=12
# Seconds without first streamed token before trying TEXT_STREAM_TIMEOUT_FALLBACK_MODEL (non-stream complete_llm).
# Default is independent of TEXT_STREAM_STATUS_INTERVAL_SECONDS.
TEXT_STREAM_FALLBACK_AFTER_SECONDS=7
# Optional faster model id to try once when first-token timeout is reached.
TEXT_STREAM_TIMEOUT_FALLBACK_MODEL=
# Circuit-break model after repeated first-token timeouts.
TEXT_STREAM_MODEL_TIMEOUT_THRESHOLD=2
TEXT_STREAM_MODEL_COOLDOWN_SECONDS=180
# Retry and control limits
MAX_RETRIES=2
MAX_TOOL_ACTIONS_PER_REQUEST=1
MAX_VISION_MODEL_ATTEMPTS=2
RESPONSE_VALIDATION_RETRY_ENABLED=true
# Optional advisory intent suggestion by LLM (system routing still enforced)
INTENT_LLM_SUGGESTION_ENABLED=false
INTENT_LLM_SUGGESTION_TIMEOUT_SECONDS=2
# Max image payload size accepted by multimodal materializer (bytes)
MAX_VISION_IMAGE_BYTES=5242880
# Max video payload size accepted before frame extraction (bytes)
MAX_VISION_VIDEO_BYTES=31457280
# Number of frames extracted from each video input
VISION_VIDEO_MAX_FRAMES=4
# Seconds between sampled video frames
VISION_VIDEO_FRAME_INTERVAL_SECONDS=2
# Optional browser profile for yt-dlp cookie extraction (e.g. chrome, firefox, safari)
VISION_YTDLP_COOKIES_FROM_BROWSER=

# =========================
# Response style
# =========================
# Make answers consistently natural/human-like from gateway level
HUMANIZE_RESPONSES=true
# Optional style override
# HUMAN_TONE_INSTRUCTION=Respond in a natural, warm, and human tone.
DEBUG_MODE=true
